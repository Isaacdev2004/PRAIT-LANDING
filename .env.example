# Copy to .env for local development. On Render, set these in the dashboard.

NODE_ENV=production
BASE_PATH=/
PORT=8080

# Required for consultation form emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=PRAIT Consulting <onboarding@yourdomain.com>

# Required for AI pathway matcher (https://platform.openai.com)
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
